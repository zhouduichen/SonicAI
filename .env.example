# ── SonicAI Production Configuration ──────────────────────────────────────────
# Copy this file to .env and adjust values for your deployment.

# Security
SECRET_KEY=change-me-in-production           # REQUIRED: change to a random 64+ char string
DEFAULT_ADMIN_PASSWORD=                      # REQUIRED in production: initial admin password

# Database (SQLite for single-node; PostgreSQL recommended for multi-worker)
DATABASE_URL=sqlite:///./aimusic.db
# DATABASE_URL=postgresql://user:pass@host:5432/sonicai

# Redis (Celery broker + result backend)
REDIS_URL=redis://redis:6379/0

# File storage
UPLOAD_DIR=./uploads
GENERATED_DIR=./generated

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Hardware tier: ultra (16G+) / high (12G+) / mid (8G+) / low (6G+) / cpu
SONICAI_HARDWARE_TIER=mid
SONICAI_PREFERENCE=speed                     # speed or quality

# Mock fallback — set to false in production to prevent silent fake audio
ENABLE_MOCK_FALLBACK=false

# HuggingFace mirror (set to https://hf-mirror.com for China)
HF_ENDPOINT=https://hf-mirror.com

# Debug mode — enables auto-migrate and detailed error pages
DEBUG=false

# LLM / Prompt Suggestions (optional)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com

# External SVS service (optional)
# SVS_API_URL=http://127.0.0.1:9880
